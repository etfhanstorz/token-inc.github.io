# Copy this file to ".env" and fill in your values.

# From the Discord Developer Portal -> your app -> Bot -> Reset Token
DISCORD_TOKEN=your-bot-token-here

# From the Developer Portal -> your app -> General Information -> Application ID
CLIENT_ID=your-application-id-here

# Optional: a single server (guild) ID to register commands instantly while testing.
# Leave blank to register globally (can take up to ~1 hour to appear).
GUILD_ID=

# MUST match ADMIN_CHANNEL in index.html exactly. Treat it like a password.
ADMIN_CHANNEL=token-casino-abcd1234

# Public MQTT broker (must match the one the game connects to).
MQTT_URL=wss://broker.emqx.io:8084/mqtt

# Comma-separated Discord user IDs allowed to run admin commands (no spaces).
# Right-click your name in Discord (Developer Mode on) -> Copy User ID.
ADMINS=

# Webhook URL for /patchnotes (a Discord channel -> Integrations -> Webhooks -> New).
PATCHNOTES_WEBHOOK_URL=
